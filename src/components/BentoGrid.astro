---
import MenuCard from './MenuCard.astro';
import menuItems from '../data/menu.json';

interface MenuItem {
  id: number;
  title: string;
  description: string;
  price: string;
  image: string;
  bentoSize: 'small' | 'wide' | 'tall';
}

const menu = menuItems as MenuItem[];
---

<section class="py-8 px-4">
  <div class="max-w-6xl mx-auto">
    <!-- Bento Grid Container -->
    <!-- Мобильные: 1 колонка, Планшет: 2 колонки, PC: 4 колонки -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6 auto-rows-[250px] sm:auto-rows-[200px] lg:auto-rows-[180px]">
      {
        menu.map((item) => (
          <MenuCard
            id={item.id}
            title={item.title}
            description={item.description}
            price={item.price}
            image={item.image}
            bentoSize={item.bentoSize}
          />
        ))
      }
    </div>
  </div>
</section>
